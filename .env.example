# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# SQL backend integration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=code_platform
DB_USER=appuser
DB_PASSWORD=change-me
JWT_SECRET=change-me-at-least-32-characters-long
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRES_DAYS=14
AI_PROVIDER=mock

# Admin panel
ADMIN_PANEL_KEY=change-me-at-least-20-characters
ADMIN_METRICS_WINDOW_MINUTES=60
ADMIN_ACTIVE_WINDOW_SECONDS=300

# Analysis queue
ANALYSIS_QUEUE_MODE=inline
ANALYSIS_QUEUE_NAME=analysis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS origins
CODE_PLATFORM_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
