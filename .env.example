# 공통 실행 환경
APP_ENV=development

# JSONL 런타임 데이터 경로
CODE_PLATFORM_DATA_DIR=data
CODE_PLATFORM_USERS_DIR=data/users

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_SECRET_FILE=
# 권장: 아래 허용 목록을 기준으로 Google Cloud Console의 승인된 리디렉션 URI를 동일하게 등록하세요.
# 운영/외부 도메인은 HTTPS만 추가하세요.
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:8000/platform/auth/google/callback,http://127.0.0.1:8000/platform/auth/google/callback,https://localhost:8443/platform/auth/google/callback,https://127.0.0.1:8443/platform/auth/google/callback
# 레거시 단일 URI 설정. 가능하면 GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS만 사용하세요.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/platform/auth/google/callback

# Gemini / 공통 AI 설정
# 일반 문제 생성은 GOOGLE_MODEL 기본값을 사용합니다.
# 학습 리포트는 코드에서 gemini-3.1-pro-preview 로 고정됩니다.
GOOGLE_API_KEY=
GOOGLE_API_KEY_FILE=
GOOGLE_MODEL=gemini-3-flash-preview
GOOGLE_API_ENDPOINT=https://generativelanguage.googleapis.com
AI_API_KEY=
AI_API_KEY_FILE=
AI_REQUEST_TIMEOUT_SECONDS=30

# OpenAI 설정 (platform AI_PROVIDER=openai 일 때 사용)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_MODEL=gpt-4o-mini

# MySQL / 플랫폼 API
DB_HOST=localhost
DB_PORT=3306
DB_NAME=code_platform
DB_USER=appuser
DB_PASSWORD=replace-with-strong-db-password
DB_PASSWORD_FILE=

# JWT / 인증
# 절대 커밋하지 말고 32자 이상 랜덤 값으로 교체하세요.
JWT_SECRET=replace-with-random-32-plus-character-secret
JWT_SECRET_FILE=
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRES_DAYS=14

# 플랫폼 비밀번호 인증
# 기본값은 false 입니다. true 로 바꾸면 /platform/auth/* 비밀번호 경로가 활성화됩니다.
ALLOW_PLATFORM_PASSWORD_AUTH=false

# 게스트 / 레거시 토큰 호환
CODE_PLATFORM_GUEST_TTL_SECONDS=300
CODE_PLATFORM_ALLOW_LEGACY_JSONL_TOKENS=false
CODE_PLATFORM_LEGACY_TOKEN_SUNSET_DATE=2026-03-31
CODE_PLATFORM_LEGACY_TOKEN_MAX_AGE_SECONDS=86400
CODE_PLATFORM_ALLOW_SIDLESS_COOKIE_COMPAT=true
CODE_PLATFORM_SIDLESS_COOKIE_SUNSET_AT=2026-04-03T23:59:59+09:00

# 관리자 패널
# 절대 커밋하지 말고 20자 이상 랜덤 값으로 교체하세요.
ADMIN_PANEL_KEY=replace-with-random-20-plus-character-admin-key
ADMIN_PANEL_KEY_FILE=
ADMIN_METRICS_WINDOW_MINUTES=60
ADMIN_ACTIVE_WINDOW_SECONDS=300
CODE_PLATFORM_ENABLE_ADMIN_SHUTDOWN=false
ADMIN_THROTTLE_BACKEND=redis

# 직접 HTTPS 실행
ENABLE_HTTPS=false
TLS_CERTS_DIR=certs
SSL_CERTFILE=
SSL_KEYFILE=
HTTPS_BIND_PORT=8443
HTTPS_PUBLIC_PORT=8443
HTTP_REDIRECT_PORT=8000

# 분석 큐 / Redis
ANALYSIS_QUEUE_MODE=inline
ANALYSIS_QUEUE_NAME=analysis
ANALYSIS_QUEUE_JOB_TIMEOUT_SECONDS=300
ANALYSIS_QUEUE_RESULT_TTL_SECONDS=3600
ANALYSIS_QUEUE_FAILURE_TTL_SECONDS=86400
ANALYSIS_PROCESSING_STALE_SECONDS=900
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 브라우저 접근 허용 Origin
# 운영/외부 Origin은 HTTPS만 추가하세요.
CODE_PLATFORM_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://localhost:8443,https://127.0.0.1:8443
